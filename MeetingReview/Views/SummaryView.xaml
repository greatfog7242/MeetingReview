<UserControl x:Class="MeetingReview.Views.SummaryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:MeetingReview.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance Type=vm:SummaryViewModel, IsDesignTimeCreatable=False}">

    <DockPanel>
        <!-- Prompt + generate button -->
        <StackPanel DockPanel.Dock="Top" Margin="8,8,8,4">
            <Label Content="Summary Prompt" FontWeight="Medium" Padding="0,0,0,2"/>
            <TextBox Text="{Binding Prompt, UpdateSourceTrigger=PropertyChanged}"
                     TextWrapping="Wrap"
                     AcceptsReturn="False"
                     Height="52"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,6"/>
            <Button Content="Generate Summary"
                    Command="{Binding GenerateSummaryCommand}"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,0,4"/>
            <Button Content="Export Markdown"
                    Command="{Binding ExportMarkdownCommand}"
                    HorizontalAlignment="Stretch">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasTopics}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

            <!-- Error message — visible only when non-null -->
            <TextBlock TextWrapping="Wrap"
                       Foreground="#C00"
                       FontSize="12"
                       Margin="0,6,0,0"
                       Text="{Binding ErrorMessage}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
        </StackPanel>

        <!-- Loading indicator -->
        <ProgressBar DockPanel.Dock="Top"
                     IsIndeterminate="True"
                     Height="3"
                     Margin="0,0,0,4">
            <ProgressBar.Style>
                <Style TargetType="ProgressBar">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ProgressBar.Style>
        </ProgressBar>

        <!-- Topic accordion -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Topics}" Padding="4">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="{Binding IsExpanded}" Margin="0,2">
                            <Expander.Header>
                                <!--
                                    Button rather than EventTrigger on Expanded,
                                    so programmatic IsExpanded changes (from HighlightTopicAt)
                                    do not trigger video navigation.
                                -->
                                <Button Content="{Binding Title}"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        FontWeight="SemiBold"
                                        HorizontalAlignment="Left"
                                        Padding="0"
                                        Cursor="Hand"
                                        Command="{Binding DataContext.NavigateToTimeCommand,
                                                  RelativeSource={RelativeSource AncestorType={x:Type Window}}}"
                                        CommandParameter="{Binding StartMs}"/>
                            </Expander.Header>
                            <TextBlock Text="{Binding DetailedContent}"
                                       TextWrapping="Wrap"
                                       Padding="12,6"
                                       Foreground="#444"
                                       FontSize="13"/>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
