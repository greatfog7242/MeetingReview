<Window x:Class="MeetingReview.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MeetingReview.Views"
        xmlns:vm="clr-namespace:MeetingReview.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}"
        Title="Meeting Review"
        Icon="/Assets/meetingreview.png"
        Height="768" Width="1366"
        MinHeight="600" MinWidth="900">

    <TabControl>
        <!-- ── Review tab ─────────────────────────────────────────── -->
        <TabItem Header="Review">
            <DockPanel>
                <!-- Top toolbar: file load commands -->
                <ToolBar DockPanel.Dock="Top">
                    <Button Content="📁  Load Video"
                            Command="{Binding LoadVideoCommand}"
                            ToolTip="Load .mov or .mp4 recording"/>
                    <Separator/>
                    <Button Content="📂  Load Recording"
                            Command="{Binding LoadRecordingCommand}"
                            ToolTip="Select a folder containing transcript.txt and transcript.json"/>
                </ToolBar>

                <!-- Three-column layout: Video | Transcript | Summary -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" MinWidth="320"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <local:VideoPlayerView Grid.Column="0"
                                           DataContext="{Binding VideoPlayer}"/>

                    <GridSplitter Grid.Column="1"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="#DDD"/>

                    <local:TranscriptView Grid.Column="2"
                                          DataContext="{Binding Transcript}"/>

                    <GridSplitter Grid.Column="3"
                                  Width="5"
                                  HorizontalAlignment="Stretch"
                                  Background="#DDD"/>

                    <local:SummaryView Grid.Column="4"
                                       DataContext="{Binding Summary}"/>
                </Grid>
            </DockPanel>
        </TabItem>

        <!-- ── Settings tab ───────────────────────────────────────── -->
        <TabItem Header="Settings">
            <local:SettingsView DataContext="{Binding Settings}"/>
        </TabItem>
    </TabControl>
</Window>
